* {
  font-family: FiraCode Nerd Font;
  font-size: 16px;
  padding: 1px 7px;
}

window#waybar {
  background-color: rgba({{base00-dec-r}}, {{base00-dec-g}}, {{base00-dec-b}}, 0.8);
  color: #{{base0F-hex}};
}

#workspaces button {
  background-color: transparent;
  color: #{{base06-hex}};
}

#workspaces button:hover {
  box-shadow: inherit;
  text-shadow: inherit;
  background: transparent;
  border: transparent;
  padding: inherit;
  color: #{{base07-hex}};
}

#workspaces button.focused, #workspaces button.active {
  color: #{{base0F-hex}};
}

/* If workspaces is the leftmost module, omit left margin */
.modules-left > widget:first-child > #workspaces {
  margin-left: 0;
}

/* If workspaces is the rightmost module, omit right margin */
.modules-right > widget:last-child > #workspaces {
  margin-right: 0;
}

#clock {
  color: #{{base06-hex}};
}

#network {
  color: #{{base04-hex}};
}

#network.disconnected {
  color: #{{base09-hex}};
}

#custom-power {
  color: #{{base0A-hex}};
}

menu {
  background: #{{base00-hex}};
  color: #{{base0A-hex}};
  padding: 4px;
}

menuitem {
  border-radius: 8px;
}

